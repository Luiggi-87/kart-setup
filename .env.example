# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Netlify Functions (server-side only)
SUPABASE_SERVICE_KEY=your-service-key-here

# Mercado Pago (when needed)
MP_ACCESS_TOKEN=your-mp-token
MP_PLAN_ID=your-plan-id
MP_WEBHOOK_SECRET=your-webhook-secret

# Site Configuration
SITE_URL=https://kartsetup.com.br
NODE_ENV=production

# Security
CSRF_TOKEN_SECRET=your-random-32-char-secret-here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
